# ============================================================
# Nextcloud sync-exclude.lst
# Place in: ~/.config/Nextcloud/sync-exclude.lst  (Linux)
#           %APPDATA%\Nextcloud\sync-exclude.lst   (Windows)
# ============================================================


# ============================================================
# SYSTEM & OS FILES
# ============================================================

# Linux
.directory
.Trash-*
lost+found

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.AppleDouble
.AppleDB
.AppleDesktop
.apdisk
Icon\r

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ============================================================
# TEMPORARY & LOCK FILES
# ============================================================

~ $*
*.tmp
*.temp
*.swp
*.swo
*.swn
*~
.~lock.*
*.part
*.crdownload
*.download
*.filepart


# ============================================================
# DATABASE LOCK FILES (Firefox, Chromium, SQLite apps)
# ============================================================

*.sqlite-wal
*.sqlite-shm
*.sqlite-journal
*.metadata-v2
storage-sync-v2*
places.sqlite-*
webappsstore.sqlite-*
cookies.sqlite-*
favicons.sqlite-*


# ============================================================
# BROWSER PROFILES (locked while browser is running)
# ============================================================

# Firefox — lock files and session data
.parentlock
lock
*.lz4
sessionstore*
recovery.js
recovery.bak
previous.js
upgrade.js-*

# Chromium / Chrome
Cookies-journal
History-journal
Network Action Predictor-journal
Visited Links


# ============================================================
# VERSION CONTROL
# ============================================================

.git/
.svn/
.hg/
.bzr/
CVS/
*.orig


# ============================================================
# PYTHON
# ============================================================

__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.env/
.tox/
.pytest_cache/
*.coverage
.mypy_cache/
.ruff_cache/


# ============================================================
# NODE / JAVASCRIPT
# ============================================================

node_modules/
.npm/
.yarn/
.pnp.*
.cache/
dist/
.next/
.nuxt/
.svelte-kit/


# ============================================================
# JAVA / MAVEN / GRADLE
# ============================================================

target/
*.class
*.jar
*.war
*.ear
.gradle/
build/


# ============================================================
# IDEs & EDITORS
# ============================================================

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.ipr
*.iws

# VSCode
.vscode/

# Eclipse
.classpath
.project
.settings/

# Sublime Text
*.sublime-workspace

# Vim / Emacs
*.un~
\#*\#
.\#*


# ============================================================
# LOGS & DEBUG OUTPUT
# ============================================================

*.log
*.log.*
*.logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ============================================================
# COMPILED & GENERATED BINARIES
# ============================================================

*.o
*.so
*.dylib
*.dll
*.exe
*.out
*.a
*.lib
*.pyc


# ============================================================
# ARCHIVES (optional — comment out if you want these synced)
# ============================================================

# *.zip
# *.tar
# *.tar.gz
# *.tgz
# *.rar
# *.7z


# ============================================================
# THUMBNAILS & CACHE DIRS
# ============================================================

.thumbnails/
.cache/
Thumbs/


# ============================================================
# NEXTCLOUD OWN ARTIFACTS
# ============================================================

._conflict-*
*_conflict-*

# Firefox profile directory
config/mozilla/firefox/